# Transcription providers (pick one, set with --transcriber)
ASSEMBLYAI_API_KEY=your_assemblyai_key_here
# DEEPGRAM_API_KEY=your_deepgram_key_here

# Polishing providers (pick one, set with --polisher)
ANTHROPIC_API_KEY=your_anthropic_key_here
# OPENAI_API_KEY=your_openai_key_here
# GOOGLE_API_KEY=your_google_api_key_here
# For Ollama: no key needed, just run `ollama serve` locally

# Optional settings
# VOXTRACT_OUTPUT_DIR=./output
# VOXTRACT_OUTPUT_FORMAT=markdown
# OLLAMA_BASE_URL=http://localhost:11434
